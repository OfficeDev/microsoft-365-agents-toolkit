<?xml version="1.0" encoding="utf-8"?>
<!--
     This configuration file is required if Python is used to run applications behind
     IIS or IIS Express on Azure App Service.
-->

<configuration>
  <system.webServer>
    <webSocket enabled="false" />
    <handlers>
      <!-- Indicates that the app.py file is a Python application to be handled by the Python handler -->
      <add name="python" path="src/app.py" verb="*" modules="httpPlatformHandler" resourceType="Unspecified"/>
    </handlers>
    <httpPlatform processPath="python" arguments="src/app.py" stdoutLogEnabled="true" stdoutLogFile=".\python.log" startupTimeLimit="20" requestTimeout="00:04:00">
      <environmentVariables>
        <environmentVariable name="PYTHONPATH" value=".\src" />
        <environmentVariable name="PORT" value="%HTTP_PLATFORM_PORT%" />
      </environmentVariables>
    </httpPlatform>
  </system.webServer>
</configuration>
