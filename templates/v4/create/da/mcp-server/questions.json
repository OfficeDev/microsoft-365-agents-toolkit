{
  "$schema": "../../../schema/question.schema.json",
  "questions": [
    {
      "name": "mcpServerType",
      "type": "singleSelect",
      "title": "MCP Server Type",
      "keyPrefix": "template.daMcpServer.mcpServerType",
      "optionsFrom": "mcp.serverTypes",
      "skipSingleOption": true,
      "default": "remote"
    },
    {
      "name": "mcpServerUrl",
      "type": "text",
      "title": "MCP Server URL",
      "keyPrefix": "template.daMcpServer.mcpServerUrl",
      "condition": { "expr": "mcpServerType == 'remote'" },
      "validation": "uri"
    },
    {
      "name": "authType",
      "type": "singleSelect",
      "title": "Authentication",
      "keyPrefix": "template.daMcpServer.authType",
      "staticOptions": [
        { "id": "oauth", "label": "OAuth (with static registration)" },
        { "id": "oauth-dynamic", "label": "OAuth (with dynamic registration)",
          "condition": { "expr": "featureFlag('TEAMSFX_MCP_FOR_DA_DT') && featureFlag('TEAMSFX_MCP_FOR_DA_DCR')" } },
        { "id": "entra-sso", "label": "Entra SSO" },
        { "id": "none", "label": "None" }
      ],
      "default": "none"
    }
  ]
}
