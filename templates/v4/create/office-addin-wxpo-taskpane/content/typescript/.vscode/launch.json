{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Word Desktop Host",
      "type": "node-terminal",
      "request": "launch",
      "command": "npm run start:desktop:word",
      "cwd": "${workspaceFolder}",
      "preLaunchTask": "Install",
      "postDebugTask": "Stop Debug",
      "presentation": {
        "hidden": true
      }
    },
    {
      "name": "Word Desktop Attach (Edge Chromium)",
      "type": "msedge",
      "request": "attach",
      "port": 9229,
      "timeout": 600000,
      "webRoot": "${workspaceRoot}",
      "presentation": {
        "hidden": true
      }
    },
    {
      "name": "Excel Desktop Host",
