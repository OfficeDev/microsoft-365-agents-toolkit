{
  "compilerOptions": {
    "module": "commonjs",
    "target": "es6",
    "outDir": "build",
    "lib": ["es6", "dom", "esnext.asynciterable"],
    "sourceMap": true,
    "rootDir": ".",
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "strict": true,
    "useUnknownInCatchVariables": false,
    "jsx": "react",
    "plugins": [],
    "esModuleInterop": true
  },
  "include": ["src"],
  "exclude": ["src/controls"],
  "ts-node": {
    "files": true
  }
}
