{
    "compilerOptions": {
        "outDir": "build",
        "target": "es2017",
        "module": "commonjs",
        "declaration": true,
        "strict": true,
        "esModuleInterop": true,
        "sourceMap": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true,
        "lib": ["es6", "dom.iterable", "dom"],
        "importHelpers": true,
        "allowJs": true,
        "declarationMap": true,
        "moduleResolution": "node",
        "resolveJsonModule": true,
        "types" : ["node"]
    },
    "include": ["src"],
    "exclude": ["node_modules", "**/__tests__/*"]
}
