{
  "compilerOptions": {
    "outDir": "build",
    "target": "ES2022",
    "module": "commonjs",
    "declaration": true,
    "declarationMap": true,
    "strict": true,
    "esModuleInterop": true,
    "sourceMap": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "lib": ["ES2022"],
    "importHelpers": true,
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "types": ["node"],
    "incremental": true,
    "rootDir": "./src"
  },
  "include": ["src"],
  "exclude": ["node_modules", "build", "tests"]
}
